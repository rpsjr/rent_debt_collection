<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 
            Template 1: Aviso de Atraso - Bloqueio em 24h 
            Uso: Padrão para atrasos
        -->
        <record id="email_template_aviso_atraso_bloqueio_24h" model="mail.template">
            <field name="name">Aviso de Atraso - Bloqueio em 24h</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="subject">Aviso de Atraso - Bloqueio em 24h</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Olá ${object.partner_id.name or ''},<br/><br/>
        Identificamos pendência na fatura <strong>${object.name}</strong>.<br/><br/>
        O bloqueio do veículo ocorrerá em <strong>24h</strong>.<br/><br/>
        Pague agora para evitar transtornos.<br/><br/>
        <div style="text-align: center; margin: 16px 0px;">
            <a href="${object.payment_url}"
                style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                VER FATURA
            </a>
        </div>
        <br/>
        <strong>PIX Copia e Cola:</strong><br/>
        <code style="background-color: #f0f0f0; padding: 5px; border-radius: 3px; display: block; word-break: break-all;">${object.pix_copy_code}</code>
        <br/><br/>
        Babur Rent
    </p>
</div>
            </field>
        </record>

        <!-- 
            Template 2: Aviso de Vencimento - Reincidente - Bloqueio em 24h 
            Uso: Reincidentes
        -->
        <record id="email_template_aviso_vencimento_reincidente_bloqueio_24h" model="mail.template">
            <field name="name">Aviso de Vencimento - Bloqueio em 24h</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="subject">Aviso de Vencimento - Bloqueio em 24h</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Olá ${object.partner_id.name or ''},<br/><br/>
        Sua fatura <strong>${object.name}</strong> está vencendo.<br/><br/>
        Caso não efetue o pagamento, o bloqueio do veículo ocorrerá em <strong>24h</strong>.<br/><br/>
        Pague até o vencimento para evitar transtornos.<br/><br/>
        <div style="text-align: center; margin: 16px 0px;">
            <a href="${object.payment_url}"
                style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                VER FATURA
            </a>
        </div>
        <br/>
        <strong>PIX Copia e Cola:</strong><br/>
        <code style="background-color: #f0f0f0; padding: 5px; border-radius: 3px; display: block; word-break: break-all;">${object.pix_copy_code}</code>
        <br/><br/>
        Babur Rent
    </p>
</div>
            </field>
        </record>

        <!-- 
            Template 3: Aviso de Bloqueio Efetuado 
            Uso: Veículo Bloqueado
        -->
        <record id="email_template_aviso_bloqueio_efetuado" model="mail.template">
            <field name="name">Veículo Bloqueado - Regularize Agora</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="subject">Veículo Bloqueado - Regularize Agora</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Olá ${object.partner_id.name or ''},<br/><br/>
        Seu veículo foi bloqueado por falta de pagamento da fatura <strong>${object.name}</strong>.<br/><br/>
        Regularize agora para desbloqueio!!!<br/><br/>
        <div style="text-align: center; margin: 16px 0px;">
            <a href="${object.payment_url}"
                style="background-color: #d9534f; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                VER FATURA
            </a>
        </div>
        <br/>
        <strong>PIX Copia e Cola:</strong><br/>
        <code style="background-color: #f0f0f0; padding: 5px; border-radius: 3px; display: block; word-break: break-all;">${object.pix_copy_code}</code>
        <br/><br/>
        Babur Rent
    </p>
</div>
            </field>
        </record>

        <!-- 
            Template 4: Aviso de Desbloqueio Solicitado 
            Uso: Veículo Desbloqueado
        -->
        <record id="email_template_aviso_desbloqueio_solicitado" model="mail.template">
            <field name="name">Veículo Desbloqueado</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="subject">Veículo Desbloqueado</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Pagamento confirmado! O veículo foi desbloqueado.<br/><br/>
        Obrigado.
    </p>
</div>
            </field>
        </record>
    </data>
</odoo>
