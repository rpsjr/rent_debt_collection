<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- 
            Template 1: Aviso de Atraso - Bloqueio em 24h 
            Uso: Faturas atrasadas que causarão bloqueio em 24h (Padrão)
        -->
        <record id="wa_template_aviso_atraso_bloqueio_24h" model="whatsapp.template">
            <field name="name">aviso_atraso_bloqueio_24h</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="language">pt_BR</field>
            <field name="header_type">TEXT</field>
            <field name="header_text">Olá {{1}}</field>
            <field name="body">Identificamos pendência na fatura {{1}}.

O bloqueio do veículo ocorrerá em 24h.

Pague agora para evitar transtornos.</field>
            <field name="footer_text">Babur Rent</field>
        </record>

        <!-- Variables for Template 1 -->
        <record id="wa_var_atraso_header" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_atraso_bloqueio_24h"/>
            <field name="name">{{1}}</field>
            <field name="location">header</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_partner_name</field>
        </record>
        
        <record id="wa_var_atraso_body" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_atraso_bloqueio_24h"/>
            <field name="name">{{1}}</field>
            <field name="location">body</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_invoice_name</field>
        </record>

        <!-- Button for Template 1 -->
        <record id="wa_btn_atraso" model="whatsapp.template.button">
            <field name="template_id" ref="wa_template_aviso_atraso_bloqueio_24h"/>
            <field name="sequence">1</field>
            <field name="type">URL</field>
            <field name="url_type">DYNAMIC</field>
            <field name="website_url">https://babur.com.br/my/invoices/{{1}}</field>
            <field name="text">VER FATURA</field>
        </record>

        <record id="wa_var_atraso_btn" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_atraso_bloqueio_24h"/>
            <field name="name">{{1}}</field>
            <field name="location">button</field>
            <field name="button_index">0</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_url_suffix</field>
        </record>


        <!-- 
            Template 2: Aviso de Vencimento - Reincidente - Bloqueio em 24h 
            Uso: Faturas vencendo hoje para reincidentes (Tol=0)
        -->
        <record id="wa_template_aviso_vencimento_reincidente_bloqueio_24h" model="whatsapp.template">
            <field name="name">aviso_vencimento_reincidente_bloqueio_24h</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="language">pt_BR</field>
            <field name="header_type">TEXT</field>
            <field name="header_text">Olá {{1}}</field>
            <field name="body">Sua fatura {{1}} está vencendo.

Caso não efetue o pagamento, o bloqueio do veículo ocorrerá em 24h.

Pague até o vencimento para evitar transtornos.</field>
            <field name="footer_text">Babur Rent</field>
        </record>

        <!-- Variables for Template 2 -->
        <record id="wa_var_reincidente_header" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_vencimento_reincidente_bloqueio_24h"/>
            <field name="name">{{1}}</field>
            <field name="location">header</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_partner_name</field>
        </record>

        <record id="wa_var_reincidente_body" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_vencimento_reincidente_bloqueio_24h"/>
            <field name="name">{{1}}</field>
            <field name="location">body</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_invoice_name</field>
        </record>

        <!-- Button for Template 2 -->
        <record id="wa_btn_reincidente" model="whatsapp.template.button">
            <field name="template_id" ref="wa_template_aviso_vencimento_reincidente_bloqueio_24h"/>
            <field name="sequence">1</field>
            <field name="type">URL</field>
            <field name="url_type">DYNAMIC</field>
            <field name="website_url">https://babur.com.br/my/invoices/{{1}}</field>
            <field name="text">VER FATURA</field>
        </record>

        <record id="wa_var_reincidente_btn" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_vencimento_reincidente_bloqueio_24h"/>
            <field name="name">{{1}}</field>
            <field name="location">button</field>
            <field name="button_index">0</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_url_suffix</field>
        </record>


        <!-- 
            Template 3: Aviso de Bloqueio Efetuado 
            Uso: Veículo bloqueado
        -->
        <record id="wa_template_aviso_bloqueio_efetuado" model="whatsapp.template">
            <field name="name">aviso_bloqueio_efetuado</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="language">pt_BR</field>
            <field name="header_type">TEXT</field>
            <field name="header_text">Olá {{1}}</field>
            <field name="body">Seu veículo foi bloqueado por falta de pagamento da fatura {{1}}.

Regularize agora para desbloqueio!!!</field>
            <field name="footer_text">Babur Rent</field>
        </record>

        <!-- Variables for Template 3 -->
        <record id="wa_var_blocked_header" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_bloqueio_efetuado"/>
            <field name="name">{{1}}</field>
            <field name="location">header</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_partner_name</field>
        </record>

        <record id="wa_var_blocked_body" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_bloqueio_efetuado"/>
            <field name="name">{{1}}</field>
            <field name="location">body</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_invoice_name</field>
        </record>

        <!-- Button for Template 3 -->
        <record id="wa_btn_blocked" model="whatsapp.template.button">
            <field name="template_id" ref="wa_template_aviso_bloqueio_efetuado"/>
            <field name="sequence">1</field>
            <field name="type">URL</field>
            <field name="url_type">DYNAMIC</field>
            <field name="website_url">https://babur.com.br/my/invoices/{{1}}</field>
            <field name="text">VER FATURA</field>
        </record>

        <record id="wa_var_blocked_btn" model="whatsapp.template.variable">
            <field name="template_id" ref="wa_template_aviso_bloqueio_efetuado"/>
            <field name="name">{{1}}</field>
            <field name="location">button</field>
            <field name="button_index">0</field>
            <field name="field_type">field</field>
            <field name="field_name">wa_url_suffix</field>
        </record>


        <!-- 
            Template 4: Aviso de Desbloqueio Solicitado 
            Uso: Veículo desbloqueado
        -->
        <record id="wa_template_aviso_desbloqueio_solicitado" model="whatsapp.template">
            <field name="model_id" ref="account.model_account_move"/>
            <field name="name">aviso_desbloqueio_solicitado</field>
            <field name="language">pt_BR</field>
            <field name="body">Pagamento confirmado! O veículo foi desbloqueado. Obrigado.</field>
            <field name="header_type">NONE</field>
            <!-- Sem botões, apenas texto informativo -->
        </record>
    </data>
</odoo>
